# ─── ChatCart Frontend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# All variables MUST start with VITE_ to be available in the browser.
#
# Full docs: docs/ENVIRONMENT_VARIABLES.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API (REQUIRED) ────────────────────────────────────────────────────
# URL of your NestJS backend API — no trailing slash
# Development (local backend):
VITE_API_BASE_URL=http://localhost:3001/v1
# Production:
# VITE_API_BASE_URL=https://api.chatcart.africa/v1

# WebSocket URL for real-time chat & notifications
VITE_WS_URL=ws://localhost:3001
# Production:
# VITE_WS_URL=wss://api.chatcart.africa

# ── WhatsApp (REQUIRED) ───────────────────────────────────────────────────────
# Default WhatsApp Business number (digits only, no + or spaces)
# Used as fallback when a seller has no individual number
VITE_WHATSAPP_PHONE=256700000000

# ── Google OAuth (enables "Sign in with Google" button) ──────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# ── Firebase Push Notifications ───────────────────────────────────────────────
# Web Push VAPID public key
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push Certificates
VITE_FCM_VAPID_KEY=

# ── Meilisearch Full-Text Search ──────────────────────────────────────────────
# Public (search-only) key — safe to expose in frontend
VITE_MEILISEARCH_URL=http://localhost:7700
VITE_MEILISEARCH_KEY=

# ── Cloudflare R2 Image CDN ───────────────────────────────────────────────────
# Public CDN domain that serves images from your R2 bucket
VITE_CLOUDFLARE_R2_URL=https://cdn.chatcart.africa

# ── Error Monitoring ──────────────────────────────────────────────────────────
VITE_SENTRY_DSN=
