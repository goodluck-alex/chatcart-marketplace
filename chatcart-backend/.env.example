# ─── ChatCart Backend Environment Variables ────────────────────────────────────
# Copy to .env and fill in your real values.
# NEVER commit .env to git.
# See docs/ENVIRONMENT_VARIABLES.md for full documentation.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatcart_db
DB_USER=chatcart_user
DB_PASS=your_dev_password
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ── JWT (generate: openssl rand -hex 64) ──────────────────────────────────────
JWT_SECRET=replace_with_256_bit_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_256_bit_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ── Africa's Talking (SMS / OTP) ──────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=ChatCart
AT_ENVIRONMENT=sandbox

# ── MTN Mobile Money ──────────────────────────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_COLLECTION_USER_ID=your_collection_user_id
MTN_MOMO_COLLECTION_API_KEY=your_collection_api_key
MTN_MOMO_COLLECTION_PRIMARY_KEY=your_primary_key
MTN_MOMO_CURRENCY=UGX
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:3001/v1/payments/mtn/callback

# ── Airtel Money ──────────────────────────────────────────────────────────────
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CURRENCY=UGX
AIRTEL_COUNTRY=UG

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

# ── Firebase FCM ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----"

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@chatcart.africa
SENDGRID_FROM_NAME=ChatCart

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=chatcart-media
R2_PUBLIC_URL=https://cdn.chatcart.africa

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=your_wa_phone_number_id
WA_ACCESS_TOKEN=your_wa_access_token
WA_VERIFY_TOKEN=your_random_verify_token

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=
